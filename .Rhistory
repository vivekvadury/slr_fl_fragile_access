# Create artifical profiles
new_profiles <- tibble(
cohort = factor(c("1931-1939", "1965-1968"), levels = levels(df_clean$cohort)),
race_eth = factor(c("Non-Hispanic white", "Non-Hispanic white"),
levels = levels(df_clean$race_eth)),
marital = factor(c("Never-married", "Never-married"),
levels = levels(df_clean$marital)),
education = factor(c("High school diploma", "High school diploma"),
levels = levels(df_clean$education))
)
# Calculate predicted probabilities using the glm model (differences)
pred_boot <- predictions(
glm_check,
newdata = new_profiles,
type = "response"
) %>%
inferences(method = "boot", R = 2)
print(pred_boot)
# Calculate predicted probabilities using the glm model (differences)
diff_boot <- comparisons(
glm_check,
variables = list(cohort = c("1931-1939", "1965-1968")),
newdata = datagrid(
model = glm_check,
race_eth = "Non-Hispanic white",
marital = "Never-married",
education = "High school diploma"
),
type = "response"
) %>%
inferences(method = "boot", R = 2)
print(diff_boot)
comparison_table <- tibble(
Approach = c("Nonparametric approach", "Model-based approach"),
`Attractive features` = c(
"Requires no functional-form/distributional assumptions and directly reports the observed proportion in the subgroup of interest.",
"Uses information from the full sample (by way of a model), often producing more precise estimates and allowing predictions for hypothetical covariate profiles."
),
Drawbacks = c(
"Likely to be imprecise when subgroup sample sizes are small because it does not use information outside that subgroup.",
"Relies on correct model specification -- misspecification can lead to biased predicted probabilities."
)
)
kable(
comparison_table,
caption = "Strengths and Limitations of Nonparametric and Model-Based Estimators"
)

# Calculating statistics and CI (by birth cohort)
np_estimates <- df_sub %>%
group_by(cohort) %>%
summarise(
n = n(),
childless_count = sum(childless),
p_hat = mean(childless),
se = sqrt(p_hat * (1 - p_hat) / n), # Sample mean of Bernoulli outcome
ci_low = p_hat - 1.96 * se,
ci_high = p_hat + 1.96 * se
)
df_sub <- df_clean %>%
filter(
race_eth == "Non-Hispanic white",
education == "High school diploma",
marital == "Never-married",
cohort %in% c("1931-1939", "1965-1968")
)
# Calculating statistics and CI (by birth cohort)
np_estimates <- df_sub %>%
group_by(cohort) %>%
summarise(
n = n(),
childless_count = sum(childless),
p_hat = mean(childless),
se = sqrt(p_hat * (1 - p_hat) / n), # Sample mean of Bernoulli outcome
ci_low = p_hat - 1.96 * se,
ci_high = p_hat + 1.96 * se
)
View(np_estimates)
# Comparing cohorts and calculating the difference in proportions
p1 <- np_estimates$p_hat[np_estimates$cohort == "1931-1939"]
n1 <- np_estimates$n[np_estimates$cohort == "1931-1939"]
p2 <- np_estimates$p_hat[np_estimates$cohort == "1965-1968"]
n2 <- np_estimates$n[np_estimates$cohort == "1965-1968"]
diff_hat <- p2 - p1
se_diff <- sqrt((p1 * (1 - p1) / n1) + (p2 * (1 - p2) / n2)) # Assumption: proportions of cohorts are independent of each other -- no overlap in observations
ci_low_diff <- diff_hat - 1.96 * se_diff
ci_high_diff <- diff_hat + 1.96 * se_diff
diff_results <- data.frame(
comparison = "1965-1968 minus 1931-1939",
estimate = diff_hat,
std_error = se_diff,
ci_low = ci_low_diff,
ci_high = ci_high_diff
)
# Subsetting data to relevant profiles
df_sub <- df_clean %>%
filter(
race_eth == "Non-Hispanic white",
education == "High school diploma",
marital == "Never-married",
cohort %in% c("1931-1939", "1965-1968")
)
# Calculating statistics and CI (by birth cohort)
np_estimates <- df_sub %>%
group_by(cohort) %>%
summarise(
n = n(),
childless_count = sum(childless),
p_hat = mean(childless),
se = sqrt(p_hat * (1 - p_hat) / n), # Sample mean of Bernoulli outcome
ci_low = p_hat - 1.96 * se,
ci_high = p_hat + 1.96 * se
)
# Comparing cohorts and calculating the difference in proportions
p1 <- np_estimates$p_hat[np_estimates$cohort == "1931-1939"]
n1 <- np_estimates$n[np_estimates$cohort == "1931-1939"]
p2 <- np_estimates$p_hat[np_estimates$cohort == "1965-1968"]
n2 <- np_estimates$n[np_estimates$cohort == "1965-1968"]
diff_hat <- p2 - p1
se_diff <- sqrt((p1 * (1 - p1) / n1) + (p2 * (1 - p2) / n2)) # Assumption: proportions of cohorts are independent of each other -- no overlap in observations
ci_low_diff <- diff_hat - 1.96 * se_diff
ci_high_diff <- diff_hat + 1.96 * se_diff
diff_results <- data.frame(
comparison = "1965-1968 minus 1931-1939",
estimate = diff_hat,
std_error = se_diff,
ci_low = ci_low_diff,
ci_high = ci_high_diff
)
# Cleaning for presentation
cohort_table <- np_estimates %>%
transmute(
Cohort = cohort,
N = n,
`Predicted probability` = round(p_hat, 3),
`95% CI lower` = round(ci_low, 3),
`95% CI upper` = round(ci_high, 3)
)
# Cleaning for presentation
cohort_table <- np_estimates %>%
mutate(
across(c(p_hat, ci_low, ci_high), ~ round(.x, 3))
) %>%
select(cohort, n, p_hat, ci_low, ci_high)
diff_table <- diff_results %>%
mutate(
across(c(estimate, ci_low, ci_high), ~ round(.x, 3))
) %>%
select(comparison, estimate, ci_low, ci_high)
kable(
cohort_table,
col.names = c("Cohort", "N", "Predicted probability", "95% CI lower", "95% CI upper"),
caption = "Nonparametric Estimates of Childlessness by Birth Cohort"
)

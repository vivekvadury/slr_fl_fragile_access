notes = c(
"Outcome: Percent foreign-born noncitizen.",
"Conley standard errors in parentheses with 150 km cutoff."
),
tex = TRUE,
depvar = "Share of Foreign Born Noncitizen"
)
logit_ll <- function(beta, y, X) {
xb <- as.vector(X %*% beta)
# log-likelihood from formula above
ll <- sum(y * xb - log1p(exp(xb)))
return(ll)
}
library(haven)
library(dplyr)
df <- read_dta("cps_00084.dta")
##################
# DATA CLEANING
##################
df_clean <- df %>%
filter(frever != 999) %>%
mutate(
# outcome: 1 = childless, 0 = ever gave birth
childless = ifelse(frever == 0, 1, 0),
# implied birth year
birth_year = year - age,
# cohort categories from the paper
cohort = case_when(
birth_year >= 1931 & birth_year <= 1939 ~ "1931-1939",
birth_year >= 1940 & birth_year <= 1944 ~ "1940-1944",
birth_year >= 1945 & birth_year <= 1949 ~ "1945-1949",
birth_year >= 1950 & birth_year <= 1954 ~ "1950-1954",
birth_year >= 1955 & birth_year <= 1959 ~ "1955-1959",
birth_year >= 1960 & birth_year <= 1964 ~ "1960-1964",
birth_year >= 1965 & birth_year <= 1968 ~ "1965-1968"
),
# race/ethnicity variables
race_eth = case_when(
hispan != 0 ~ "Hispanic",
hispan == 0 & race == 200 ~ "Non-Hispanic black",
hispan == 0 & race == 100 ~ "Non-Hispanic white",
TRUE ~ "Other race"
),
# marital status
marital = ifelse(marst == 6, "Never-married", "Ever-married"),
# education
education = case_when(
educ <= 60 | educ == 71 | educ == 72 ~ "No high school diploma",
educ == 73 ~ "High school diploma",
educ %in% c(81, 91, 92) ~ "Some college",
educ >= 111 ~ "Bachelor's degree or more"
)
) %>%
mutate(
cohort  = factor(cohort,
levels = c("1931-1939", "1940-1944", "1945-1949",
"1950-1954", "1955-1959", "1960-1964",
"1965-1968")),
race_eth = factor(race_eth,
levels = c("Non-Hispanic white", "Non-Hispanic black",
"Hispanic", "Other race")),
marital = factor(marital,
levels = c("Ever-married", "Never-married")),
education   = factor(education,
levels = c("High school diploma", "No high school diploma",
"Some college", "Bachelor's degree or more"))
)
##################
# MLE OPTIMIZATION
##################
X <- model.matrix(childless ~ cohort + race_eth + marital + education, data = df_clean)
Y <- df_clean$childless
betas <- rep(0, ncol(X)) # initalizing to zero
results <- optim(
par     = betas,
fn      = logit_ll,
y       = Y,
X       = X,
method  = "BFGS",
control = list(fnscale = -1), # need to maximize
hessian = TRUE
)
# MLE estimates
beta_hat <- results$par
vcov_hat <- solve(-results$hessian)
se_mle   <- sqrt(diag(vcov_hat))
names(se_mle) <- colnames(X)
results <- data.frame(
coefficent = colnames(X),
estimate = round(beta_hat, 2),
std_error = round(se_mle, 2)
)
print(results)
glm_check <- glm(
childless ~ cohort + race_eth + marital + education,
data = df_clean,
family = binomial(link = "logit")
)
library(modelsummary)
coef_labels <- c(
"(Intercept)" = "Intercept",
"cohort1940-1944" = "Birth cohort: 1940--1944",
"cohort1945-1949" = "Birth cohort: 1945--1949",
"cohort1950-1954" = "Birth cohort: 1950--1954",
"cohort1955-1959" = "Birth cohort: 1955--1959",
"cohort1960-1964" = "Birth cohort: 1960--1964",
"cohort1965-1968" = "Birth cohort: 1965--1968",
"race_ethNon-Hispanic black" = "Non-Hispanic black",
"race_ethHispanic" = "Hispanic",
"race_ethOther race" = "Other race",
"maritalNever-married" = "Never married",
"educationNo high school diploma" = "No high school diploma",
"educationSome college" = "Some college",
"educationBachelor's degree or more" = "Bachelor's degree or more"
)
gof_map <- data.frame(
raw = c("nobs", "logLik", "AIC"),
clean = c("N", "Log-Likelihood", "AIC"),
fmt = c(0, 2, 2)
)
modelsummary(
list("Model 5" = glm_check),
coef_map = coef_labels,
statistic = "({std.error})",
stars = c("*" = .05, "**" = .01, "***" = .001),
gof_map = gof_map,
title = "Logistic Regression Predicting Childlessness",
output = "markdown"
)
library(marginaleffects)
ame <- avg_comparisons(glm_check,
variables = c("cohort", "race_eth", "marital", "education")
)
print(ame)
# avg_slopes and avg_comparisons returns the same standard errors! even though avg_slopes is for continuous predictors ...
ame_boot <- avg_comparisons(
glm_check,
variables = c("cohort", "race_eth", "marital", "education")
) %>%
inferences(method = "boot", R = 500) # is this right?
ame_boot <- avg_comparisons(glm_check,
variables = c("cohort", "race_eth", "marital", "education"),
vcov = "bootstrap",
iterations = 500
)
ame_boot <- avg_slopes(glm_check,
variables = c("cohort", "race_eth", "marital", "education"),
vcov = "bootstrap",
iterations = 500
)
ame_boot <- avg_comparisons(
glm_check,
variables = c("cohort", "race_eth", "marital", "education")
) %>%
inferences(method = "boot", R = 200)
View(ame_boot)
print(ame_boot)
logit_ll <- function(beta, y, X) {
xb <- as.vector(X %*% beta)
# log-likelihood from formula above
ll <- sum(y * xb - log1p(exp(xb)))
return(ll)
}
